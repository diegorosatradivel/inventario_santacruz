# URL base de MongoDB Atlas Data API
# Ejemplo: https://data.mongodb-api.com/app/tu-app-id/endpoint/data/v1
MONGODB_ATLAS_DATA_API_URL=

# API Key de Atlas con permisos sobre la colección de usuarios
MONGODB_ATLAS_DATA_API_KEY=

# Nombre de base de datos y colección donde se guardan los usuarios
MONGODB_ATLAS_DATABASE=inventario_santacruz
MONGODB_ATLAS_COLECCION_USUARIOS=usuarios
